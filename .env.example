# ── Offentlige klientvariabler (VITE_ = eksponeres i browseren, ALDRIG hemmeligheder) ──
# Brand for dette deployment: autohuset-vest | autohuset-v
VITE_BRAND_KEY=autohuset-vest
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Offentlig side-URL (bruges til canonical, sitemap, OG)
VITE_SITE_URL=

# Tracking (offentlige ID'er – aktiveres KUN efter samtykke)
VITE_GTM_ID=
VITE_GA4_ID=
VITE_GOOGLE_ADS_ID=
VITE_META_PIXEL_ID=

# ── Servervariabler (Supabase Edge Function secrets – må ALDRIG være VITE_) ──
# Sættes med: supabase secrets set NAVN=værdi
SUPABASE_SERVICE_ROLE_KEY=

# Nummerpladeopslag: mock | motorapi | nummerpladeapi | tjekbil | synsbasen
VEHICLE_LOOKUP_PROVIDER=mock
VEHICLE_LOOKUP_API_URL=
VEHICLE_LOOKUP_API_KEY=
# Feature flag: sæt til "false" for at deaktivere opslag helt
VEHICLE_LOOKUP_ENABLED=true

# E-mail: mock | resend | postmark | smtp
EMAIL_PROVIDER=mock
EMAIL_API_KEY=
EMAIL_FROM_ADDRESS=
# Fallback-leadmodtager hvis brandets modtager ikke er sat i databasen
ADMIN_LEAD_EMAIL=

SITE_URL=
ADMIN_URL=
